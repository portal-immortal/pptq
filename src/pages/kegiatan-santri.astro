---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import GalleryGrid from '../components/GalleryGrid.astro';
import CTASection from '../components/CTASection.astro';

const base = '/pesantren-website';

const activities = [
  {
    icon: '🌙',
    title: 'Qiyamul Lail',
    desc: 'Shalat malam bersama menjadi rutinitas santriwati PPTQ, membangun kedekatan dengan Allah dan mempererat ukhuwah.',
    category: 'Ibadah',
  },
  {
    icon: '📖',
    title: 'Setoran Hafalan',
    desc: 'Setiap hari santriwati menyetorkan hafalan baru kepada ustadzah pembimbing, memastikan target hafalan tercapai.',
    category: 'Tahfidz',
  },
  {
    icon: '📚',
    title: 'Kajian Kitab',
    desc: 'Pengajian kitab kuning dengan metode bandongan dan sorogan, mendalami ilmu dari ulama salafus shalih.',
    category: 'Ilmu',
  },
  {
    icon: '⚽',
    title: 'Olahraga & Seni',
    desc: 'Kegiatan olahraga rutin dan seni islami untuk menjaga kesehatan fisik dan mengembangkan bakat santri.',
    category: 'Ekstrakurikuler',
  },
  {
    icon: '🎤',
    title: 'Muhadhoroh',
    desc: 'Latihan pidato 3 bahasa (Indonesia, Arab, Inggris) untuk melatih keberanian dan kemampuan public speaking.',
    category: 'Keterampilan',
  },
  {
    icon: '🌱',
    title: 'Kemandirian',
    desc: 'Program kemandirian: memasak, berkebun, dan keterampilan hidup untuk membentuk santri yang mandiri.',
    category: 'Life Skill',
  },
  {
    icon: '🤝',
    title: 'Bakti Sosial',
    desc: 'Kegiatan sosial kemasyarakatan: mengajar TPA di sekitar pesantren, membantu warga, dan kegiatan sosial.',
    category: 'Sosial',
  },
  {
    icon: '✈️',
    title: 'Rihlah Tarbawiyah',
    desc: 'Perjalanan edukatif ke tempat-tempat bersejarah Islam dan lembaga pendidikan terkemuka setiap tahun.',
    category: 'Pendidikan',
  },
];

const allActivityImages = Array.from({ length: 20 }, (_, i) => ({
  src: `${base}/images/students-activities/pesantren-kegiatan-santri-${String(i + 1).padStart(2, '0')}.jpeg`,
  alt: `Kegiatan santriwati PPTQ ${i + 1}`,
}));
---

<BaseLayout title="Kegiatan Santri" description="Berbagai kegiatan santri di PPTQ Nurul Iman — dari tahfidz hingga ekstrakurikuler yang membentuk karakter islami.">
  <HeroSection
    variant="page"
    title="Kegiatan Santri"
    subtitle="Setiap hari di pesantren adalah hari yang penuh makna. Dari subuh hingga malam, santri PPTQ menjalani rutinitas yang membentuk karakter dan meningkatkan ibadah."
    bgImage={`${base}/images/students-activities/pesantren-kegiatan-santri-03.jpeg`}
    minHeight="min-h-[60vh]"
  />

  <!-- Activities Grid -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14 reveal">
        <span class="inline-block px-4 py-1 text-xs font-bold uppercase tracking-widest text-forest-700 bg-forest-50 rounded-full border border-forest-100 mb-5">
          Kegiatan Rutin
        </span>
        <h2 class="font-display font-bold text-4xl text-ink-900 mb-4">Aktivitas Penuh Berkah</h2>
        <p class="text-ink-800/55 max-w-xl mx-auto">
          Setiap kegiatan dirancang untuk membentuk santri yang seimbang antara ibadah, ilmu, dan amal.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {activities.map((a, i) => (
          <div
            class="bg-white border border-gray-100 rounded-2xl p-6 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 reveal"
            style={`animation-delay: ${i * 0.07}s`}
          >
            <div class="flex items-center justify-between mb-3">
              <span class="text-3xl">{a.icon}</span>
              <span class="px-2 py-0.5 text-xs font-medium bg-forest-50 text-forest-700 rounded-full">{a.category}</span>
            </div>
            <h4 class="font-display font-semibold text-ink-900 mb-2">{a.title}</h4>
            <p class="text-sm text-ink-800/55 leading-relaxed">{a.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Photo documentation -->
  <section class="py-24 bg-forest-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <span class="inline-block px-4 py-1 text-xs font-bold uppercase tracking-widest text-amber-400 bg-amber-500/10 rounded-full border border-amber-500/20 mb-5">
          Dokumentasi
        </span>
        <h2 class="font-display font-bold text-4xl text-white mb-4">Momen Kegiatan Santri</h2>
        <p class="text-forest-300 max-w-xl mx-auto">
          Sekilas pandang kehidupan santri PPTQ yang penuh semangat dan keberkahan.
        </p>
      </div>
      <GalleryGrid images={allActivityImages} columns={4} />
    </div>
  </section>

  <!-- Ekstrakurikuler -->
  <section class="py-24 bg-parchment-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <span class="inline-block px-4 py-1 text-xs font-bold uppercase tracking-widest text-forest-700 bg-forest-50 rounded-full border border-forest-100 mb-5">
          Ekstrakurikuler
        </span>
        <h2 class="font-display font-bold text-3xl text-ink-900">Pengembangan Minat & Bakat</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
        {[
          '⚽ Futsal', '🏸 Badminton', '🥋 Pencak Silat',
          '🎨 Kaligrafi', '🎵 Nasyid', '📰 Jurnalistik',
          '💻 Komputer', '🌿 Berkebun', '📸 Fotografi',
          '🎭 Drama Islami', '🔬 Sains', '💰 Wirausaha',
        ].map((item, i) => (
          <div class="bg-white rounded-xl p-4 text-center shadow-sm hover:shadow-md transition-shadow reveal" style={`animation-delay: ${i * 0.05}s`}>
            <p class="text-sm font-medium text-gray-700">{item}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    title="Rasakan Pengalaman Pesantren"
    subtitle="Bergabunglah dan rasakan sendiri kehidupan penuh berkah di PPTQ bersama ratusan santri dari seluruh Indonesia."
    ctaLabel="Daftar Sekarang"
    ctaHref={`${base}/pendaftaran`}
  />
</BaseLayout>
