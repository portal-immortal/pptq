---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const beritaEntries = await getCollection('berita');
  return beritaEntries.map(entry => ({
    params: { slug: entry.slug },
    props:  { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const base = '';

const formattedDate = new Date(entry.data.date).toLocaleDateString('id-ID', {
  year: 'numeric', month: 'long', day: 'numeric',
});

// Related posts
const allBerita = await getCollection('berita');
const related = allBerita
  .filter(p => p.slug !== entry.slug)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

<BaseLayout title={entry.data.title} description={entry.data.excerpt} ogImage={entry.data.image}>
  <!-- Hero image -->
  <div class="relative h-[50vh] min-h-[320px] overflow-hidden">
    <img
      src={entry.data.image}
      alt={entry.data.title}
      class="w-full h-full object-cover"
      onerror="this.src='https://placehold.co/1200x600/15803d/ffffff?text=PPTQ+News'"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 p-8 max-w-4xl mx-auto">
      <div class="flex flex-wrap gap-2 mb-3">
        {entry.data.tags?.map(tag => (
          <span class="px-3 py-1 text-xs font-medium bg-forest-600/80 text-white rounded-full">{tag}</span>
        ))}
      </div>
      <h1 class="font-display font-bold text-3xl md:text-4xl text-white leading-tight">{entry.data.title}</h1>
    </div>
  </div>

  <!-- Content -->
  <article class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Meta -->
      <div class="flex items-center gap-6 text-sm text-gray-400 mb-10 pb-6 border-b border-gray-100">
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
          {formattedDate}
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
          {entry.data.author}
        </span>
      </div>

      <!-- Body -->
      <div class="prose-islamic">
        <Content />
      </div>

      <!-- Back -->
      <div class="mt-12 pt-8 border-t border-gray-100">
        <a href={`${base}/berita`} class="inline-flex items-center gap-2 text-forest-700 font-semibold hover:text-forest-900 transition-colors">
          <svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
          Kembali ke Berita
        </a>
      </div>
    </div>
  </article>

  <!-- Related -->
  {related.length > 0 && (
    <section class="py-16 bg-parchment-100">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="font-display font-bold text-2xl text-gray-800 mb-8">Berita Terkait</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {related.map(post => (
            <a href={`${base}/berita/${post.slug}`} class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow">
              <div class="aspect-video overflow-hidden">
                <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" decoding="async"
                  onerror="this.src='https://placehold.co/400x250/15803d/ffffff?text=PPTQ'" />
              </div>
              <div class="p-5">
                <p class="text-xs text-gray-400 mb-2">
                  {new Date(post.data.date).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })}
                </p>
                <h3 class="font-display font-semibold text-gray-800 group-hover:text-forest-700 transition-colors line-clamp-2">{post.data.title}</h3>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
