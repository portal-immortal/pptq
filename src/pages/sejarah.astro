---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import Timeline from '../components/Timeline.astro';
import CTASection from '../components/CTASection.astro';

const base = '';

const timelineItems = [
  {
    year: '2006',
    title: "Berdirinya PPTQ Nurul Iman",
    description: "Atas izin Allah SWT dan tekad yang kuat, PPTQ Nurul Iman resmi berdiri di Kampung Cipayung, Desa Sukaharja, Kecamatan Ciomas, Kabupaten Bogor. Berawal dari halaqah kecil yang dipimpin langsung oleh pengasuh.",
    highlight: true,
  },
  {
    year: '2008',
    title: 'Pembangunan Asrama Santri',
    description: "Seiring bertambahnya santriwati yang datang dari berbagai daerah, dibangun asrama untuk menampung para penghafal Al-Qur'an yang ingin mondok secara penuh.",
    highlight: false,
  },
  {
    year: '2010',
    title: 'Program Santriwati Resmi Berkembang',
    description: "Di bawah bimbingan Umi Hj. Eli HS, SQ, program khusus santriwati resmi dibuka dengan asrama santriwati, merespons antusiasme tinggi dari keluarga yang ingin menitipkan putrinya.",
    highlight: false,
  },
  {
    year: '2012',
    title: 'Wisuda Tahfidz Pertama',
    description: "Momentum bersejarah: santriwati angkatan pertama berhasil menyelesaikan hafalan Al-Qur'an 30 juz dan diwisuda dalam upacara yang penuh haru dan keberkahan.",
    highlight: true,
  },
  {
    year: '2015',
    title: "Pengembangan Program & Fasilitas",
    description: "Pesantren terus berkembang dengan penambahan program kajian ilmu syar'i, pembangunan musholla yang lebih besar, dan peningkatan fasilitas asrama santriwati.",
    highlight: false,
  },
  {
    year: '2018',
    title: 'Dikenal Lebih Luas',
    description: "Kisah perjuangan dan dedikasi keluarga besar PPTQ Nurul Iman mendapat perhatian media, memperluas jangkauan pesantren ke santriwati dari berbagai wilayah Indonesia.",
    highlight: false,
  },
  {
    year: '2020',
    title: 'Adaptasi di Masa Pandemi',
    description: "Di tengah tantangan pandemi, PPTQ Nurul Iman tetap beroperasi dengan protokol kesehatan ketat, memastikan kegiatan tahfidz dan pendidikan santriwati tidak terhenti.",
    highlight: false,
  },
  {
    year: '2023',
    title: 'Penguatan Sistem Pendidikan',
    description: "Penguatan kurikulum tahfidz, pembinaan ustadzah, serta peningkatan metode pembelajaran untuk memastikan kualitas hafalan dan akhlak santriwati semakin baik.",
    highlight: false,
  },
  {
    year: '2025',
    title: 'PPTQ Nurul Iman Hari Ini',
    description: "Kini PPTQ Nurul Iman terus berkembang dengan santri aktif santriwati dari berbagai daerah, mengemban amanah untuk terus melahirkan generasi penghafal Al-Qur'an yang berakhlak mulia.",
    highlight: true,
  },
];
---

<BaseLayout
  title="Sejarah Pesantren"
  description="Perjalanan panjang PPTQ Nurul Iman sejak berdiri tahun 2006 di Ciomas, Bogor hingga kini."
  ogImage={`${base}/images/students-activities/pesantren-kegiatan-santri-04.jpeg`}
>
  <HeroSection
    variant="page"
    title="Sejarah Pesantren"
    subtitle="Perjalanan dua dekade PPTQ Nurul Iman dalam mendidik generasi penghafal Al-Qur'an di Desa Cipayung - Ciomas, Bogor."
    bgImage={`${base}/images/students-activities/pesantren-kegiatan-santri-04.jpeg`}
    minHeight="min-h-[60vh]"
  />

  <!-- Intro -->
  <section class="py-20 bg-white" aria-labelledby="sejarah-intro">
    <div class="max-w-3xl mx-auto px-4 text-center reveal">
      <span class="inline-block px-4 py-1 text-xs font-bold uppercase tracking-widest text-forest-700 bg-forest-50 rounded-full border border-forest-100 mb-6">
        Perjalanan Kami
      </span>
      <h2 id="sejarah-intro" class="font-display font-bold text-4xl text-ink-900 mb-6">
        Dari Halaqah Kecil<br/>Menuju Pesantren Berkah
      </h2>
      <p class="text-ink-800/70 leading-relaxed mb-6">
        Pondok Pesantren Tahfidzil Qur'an (PPTQ) "Nurul Iman" mulai dirintis sejak tahun 2002, oleh KH. ENJEN ZAINUDDIN (almarhum) dengan dibantu oleh anak-anak dan keponakan beliau yaitu:
      </p>

      <div class="bg-parchment-50 rounded-lg p-6 mb-6 border border-forest-100">
        <ol class="text-ink-800/70 leading-relaxed space-y-2">
          <li class="flex items-start gap-3">
            <span class="w-6 h-6 rounded-full bg-forest-600 text-white flex items-center justify-center text-xs font-bold flex-shrink-0 mt-0.5">1</span>
            <span>KH. Ubaidilah</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-6 h-6 rounded-full bg-forest-600 text-white flex items-center justify-center text-xs font-bold flex-shrink-0 mt-0.5">2</span>
            <span>KH. Djawawi</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-6 h-6 rounded-full bg-forest-600 text-white flex items-center justify-center text-xs font-bold flex-shrink-0 mt-0.5">3</span>
            <span>KH. Abdul Wadud</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-6 h-6 rounded-full bg-forest-600 text-white flex items-center justify-center text-xs font-bold flex-shrink-0 mt-0.5">4</span>
            <span>KH. Miftah Hurrido</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-6 h-6 rounded-full bg-forest-600 text-white flex items-center justify-center text-xs font-bold flex-shrink-0 mt-0.5">5</span>
            <span>KH. Zaenal Arifin</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-6 h-6 rounded-full bg-forest-600 text-white flex items-center justify-center text-xs font-bold flex-shrink-0 mt-0.5">6</span>
            <span>Ust. Nurul Fajri</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-6 h-6 rounded-full bg-forest-600 text-white flex items-center justify-center text-xs font-bold flex-shrink-0 mt-0.5">7</span>
            <span>Ust. Syaiful</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-6 h-6 rounded-full bg-forest-600 text-white flex items-center justify-center text-xs font-bold flex-shrink-0 mt-0.5">8</span>
            <span>Ust. Djayadi</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-6 h-6 rounded-full bg-forest-600 text-white flex items-center justify-center text-xs font-bold flex-shrink-0 mt-0.5">9</span>
            <span>Ust. Endang Irawan (Bang Soplo)</span>
          </li>
        </ol>
      </div>

      <p class="text-ink-800/70 leading-relaxed mb-6">
        Saat ini, KH. Ubaidilah dibantu sang istri, Ustadzah Ely Hillyatussolihah, SQ adalah Pemimpin dan Pengasuh di Pondok Pesantren Tahfidzil Qur'an (PPTQ) "Nurul Iman". Seluruh pengurus telah menempuh perjalanan dan pembelajaran tentang bagaimana mengurus pondok pesantren yang tentu tidak mudah, dan para pengurus terus bahu membahu berjuang untuk membesarkan pondok pesantren, dengan menghadapi banyak ujian dan tantangan.
      </p>

      <p class="text-ink-800/70 leading-relaxed">
        Alhamdulillah Pondok Pesantren Tahfidzil Qur'an (PPTQ) "Nurul Iman" Putri sampai saat ini telah berkembang pesat dan meraih banyak prestasi. Dengan izin Allah SWT, dukungan masyarakat, dan semangat para santriwati, pesantren ini terus tumbuh menjadi rumah bagi para pencinta Al-Qur'an dari berbagai penjuru Indonesia.
      </p>
    </div>
  </section>

  <!-- Timeline -->
  <section class="py-20 bg-parchment-100" aria-labelledby="timeline-heading">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 reveal">
        <h2 id="timeline-heading" class="font-display font-bold text-3xl text-ink-900">
          Tonggak Perjalanan PPTQ Nurul Iman
        </h2>
        <p class="text-ink-800/55 mt-2 text-sm">2002 — Sekarang</p>
      </div>
      <Timeline items={timelineItems} />
    </div>
  </section>

  <!-- Islamic Quote -->
  <section class="py-20 bg-white" aria-labelledby="quote-heading">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-gradient-to-br from-forest-800 to-forest-950 rounded-3xl p-12 lg:p-16 text-center reveal">
        <div class="mb-8">
          <span class="inline-block px-4 py-1 text-xs font-bold uppercase tracking-widest text-amber-400 bg-amber-500/10 rounded-full border border-amber-500/20 mb-6">
            Hadits tentang Ilmu
          </span>
          <h2 id="quote-heading" class="font-display font-bold text-2xl lg:text-3xl text-white mb-8">
            Pentingnya Tholabul 'Ilmi
          </h2>
        </div>

        <blockquote class="mb-8">
          <p class="font-arabic text-3xl lg:text-4xl text-amber-400 mb-4 leading-relaxed" lang="ar">
            طَلَبُ الْعِلْمِ فَرِيضَةٌ عَلَى كُلِّ مُسْلِمٍ
          </p>
          <p class="text-amber-300 text-lg mb-2">"Tholabul 'ilmi faridhotun 'ala kulli muslim"</p>
          <p class="text-forest-300 text-sm">"Mencari ilmu adalah kewajiban bagi setiap muslim"</p>
        </blockquote>

        <div class="border-t border-forest-700 pt-8">
          <p class="font-arabic text-xl text-amber-400 mb-2" lang="ar">
            مَنْ سَلَكَ طَرِيقًا يَلْتَمِسُ فِيهِ عِلْمًا سَهَّلَ اللَّهُ لَهُ طَرِيقًا إِلَى الْجَنَّةِ
          </p>
          <p class="text-forest-300 text-sm italic">
            "Barangsiapa menempuh jalan untuk mencari ilmu, maka Allah akan memudahkan baginya jalan menuju surga"
          </p>
          <cite class="text-forest-400 text-xs mt-2 block">- HR. Muslim</cite>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    title="Jadilah Bagian dari Sejarah PPTQ Nurul Iman"
    subtitle="Setiap santriwati yang belajar di PPTQ Nurul Iman adalah bagian dari perjalanan panjang perjuangan menjaga Al-Qur'an."
    ctaLabel="Daftar Sekarang"
    ctaHref={`${base}/pendaftaran`}
    secondLabel="Hubungi Kami"
    secondHref={`${base}/kontak`}
  />
</BaseLayout>
