---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';

const base = '';
---

<BaseLayout
  title="Hubungi Kami"
  description="Hubungi PPTQ Nurul Iman Ciomas Bogor — alamat, nomor WhatsApp pengasuh, email, dan formulir pesan."
>
  <HeroSection
    variant="page"
    title="Hubungi Kami"
    subtitle="Kami siap menjawab pertanyaan Anda seputar pendaftaran, program, dan kehidupan di pesantren."
    bgImage={`${base}/images/students-activities/pesantren-kegiatan-santri-15.jpeg`}
    minHeight="min-h-[50vh]"
  />

  <section class="py-20 bg-parchment-100" aria-labelledby="kontak-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

        <!-- ── Sidebar ── -->
        <aside class="space-y-6 reveal-left" aria-label="Informasi kontak">
          <div>
            <span class="chip chip-forest mb-4">Info Kontak</span>
            <h2 id="kontak-heading" class="font-display text-3xl text-ink-900">Temukan Kami</h2>
          </div>

          <!-- Contact details -->
          <address class="not-italic space-y-4">
            {[
              {
                icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>`,
                label: 'Alamat',
                content: 'Kp. Cipayung No.1, Desa Sukaharja, Kec. Ciomas, Kab. Bogor, Jawa Barat 16610',
                href: 'https://maps.app.goo.gl/os3twwASvpf2DxaZ6',
                linkText: 'Buka Google Maps →',
              },
              {
                icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>`,
                label: 'Email',
                content: 'pptqnurulimancipayung@gmail.com',
                href: 'mailto:pptqnurulimancipayung@gmail.com',
              },
              {
                icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
                label: 'Jam Layanan',
                content: 'Senin – Sabtu: 08.00 – 16.00 WIB',
              },
            ].map(item => (
              <div class="flex items-start gap-4 bg-white rounded-xl p-4 border border-parchment-300 shadow-sm">
                <div class="w-9 h-9 rounded-lg bg-forest-50 flex items-center justify-center flex-shrink-0">
                  <svg class="w-4.5 h-4.5 text-forest-700" style="width:18px;height:18px" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <Fragment set:html={item.icon} />
                  </svg>
                </div>
                <div>
                  <p class="text-2xs font-bold uppercase tracking-widest text-forest-600 mb-0.5">{item.label}</p>
                  {item.href ? (
                    <a href={item.href} class="text-sm text-ink-800 hover:text-forest-700 transition-colors leading-relaxed">{item.content}</a>
                  ) : (
                    <p class="text-sm text-ink-800 leading-relaxed">{item.content}</p>
                  )}
                  {item.linkText && (
                    <a href={item.href} target="_blank" rel="noopener noreferrer" class="text-xs text-amber-600 hover:text-amber-700 transition-colors font-semibold block mt-0.5">{item.linkText}</a>
                  )}
                </div>
              </div>
            ))}
          </address>

          <!-- Two WA buttons -->
          <div class="space-y-3">
            <p class="text-xs font-bold uppercase tracking-widest text-ink-800/40">Hubungi Pengasuh</p>
            {[
              { label: 'Umi Hj. Eli HS, SQ', sub: 'Ustadzah & Pengasuh Pondok Pesantren', wa: '6285887516141', num: '0858-8751-6141' },
              { label: 'KH. Ubaidilah',       sub: 'Pimpinan Pondok Pesantren', wa: '6281317030272', num: '0813-1703-0272' },
            ].map(p => (
              <a
                href={`https://wa.me/${p.wa}?text=Assalamualaikum%2C%20saya%20ingin%20bertanya%20tentang%20PPTQ%20Nurul%20Iman`}
                target="_blank" rel="noopener noreferrer"
                class="flex items-center gap-3 w-full p-3.5 bg-green-600 hover:bg-green-500 text-white rounded-xl transition-all hover:scale-[1.02] shadow-md group"
              >
                <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                <div class="flex-1 min-w-0">
                  <p class="font-bold text-xs leading-tight">{p.label}</p>
                  <p class="text-xs text-green-100 leading-tight">{p.sub} · {p.num}</p>
                </div>
                <svg class="w-4 h-4 opacity-60 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
            ))}
          </div>

          <!-- Instagram -->
          <a href="https://instagram.com/pptqnuruliman_official" target="_blank" rel="noopener noreferrer"
            class="flex items-center gap-3 w-full p-3.5 bg-white border-2 border-parchment-300 hover:border-amber-300 text-ink-800 rounded-xl transition-all group">
            <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-purple-500 to-pink-500 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            </div>
            <div class="flex-1">
              <p class="font-semibold text-xs">Instagram</p>
              <p class="text-xs text-ink-800/50">@pptqnuruliman_official</p>
            </div>
            <svg class="w-4 h-4 text-ink-800/30 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </aside>

        <!-- ── Main: form + map ── -->
        <div class="lg:col-span-2 space-y-7 reveal-right">

          <!-- Contact form -->
          <div class="bg-white rounded-2xl p-7 sm:p-8 border border-parchment-300 shadow-card">
            <h3 class="font-display text-2xl text-ink-900 mb-1">Kirim Pesan</h3>
            <p class="text-sm text-ink-800/50 mb-7">Kami akan membalas dalam 1×24 jam di hari kerja.</p>

            <form id="contact-form" novalidate class="space-y-5" aria-label="Formulir kontak">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="nama" class="block text-xs font-bold uppercase tracking-wide text-ink-800/60 mb-2">
                    Nama Lengkap <span class="text-red-400">*</span>
                  </label>
                  <input id="nama" name="nama" type="text" required autocomplete="name" placeholder="Nama Anda"
                    class="w-full px-4 py-3 rounded-xl border border-parchment-300 bg-parchment-50 focus:outline-none focus:ring-2 focus:ring-forest-500 focus:border-transparent text-sm transition-all" />
                </div>
                <div>
                  <label for="wa" class="block text-xs font-bold uppercase tracking-wide text-ink-800/60 mb-2">
                    No. WhatsApp <span class="text-red-400">*</span>
                  </label>
                  <input id="wa" name="wa" type="tel" required autocomplete="tel" placeholder="0812-xxxx-xxxx"
                    class="w-full px-4 py-3 rounded-xl border border-parchment-300 bg-parchment-50 focus:outline-none focus:ring-2 focus:ring-forest-500 focus:border-transparent text-sm transition-all" />
                </div>
              </div>
              <div>
                <label for="email" class="block text-xs font-bold uppercase tracking-wide text-ink-800/60 mb-2">Email</label>
                <input id="email" name="email" type="email" autocomplete="email" placeholder="email@contoh.com"
                  class="w-full px-4 py-3 rounded-xl border border-parchment-300 bg-parchment-50 focus:outline-none focus:ring-2 focus:ring-forest-500 focus:border-transparent text-sm transition-all" />
              </div>
              <div>
                <label for="subjek" class="block text-xs font-bold uppercase tracking-wide text-ink-800/60 mb-2">
                  Subjek <span class="text-red-400">*</span>
                </label>
                <select id="subjek" name="subjek" required
                  class="w-full px-4 py-3 rounded-xl border border-parchment-300 bg-parchment-50 focus:outline-none focus:ring-2 focus:ring-forest-500 focus:border-transparent text-sm transition-all">
                  <option value="">Pilih subjek pesan</option>
                  <option>Informasi Pendaftaran Santri Baru</option>
                  <option>Pertanyaan Program Pendidikan</option>
                  <option>Informasi Biaya & Beasiswa</option>
                  <option>Kerjasama & Kemitraan</option>
                  <option>Lainnya</option>
                </select>
              </div>
              <div>
                <label for="pesan" class="block text-xs font-bold uppercase tracking-wide text-ink-800/60 mb-2">
                  Pesan <span class="text-red-400">*</span>
                </label>
                <textarea id="pesan" name="pesan" required rows="5"
                  placeholder="Tuliskan pesan atau pertanyaan Anda di sini..."
                  class="w-full px-4 py-3 rounded-xl border border-parchment-300 bg-parchment-50 focus:outline-none focus:ring-2 focus:ring-forest-500 focus:border-transparent text-sm resize-none transition-all"></textarea>
              </div>
              <button type="submit" id="submit-btn"
                class="w-full py-4 bg-forest-900 hover:bg-forest-700 text-white font-bold rounded-xl shadow-md transition-all hover:scale-[1.01] text-sm tracking-wide">
                Kirim Pesan
              </button>
              <div id="success-msg" role="alert" class="hidden bg-green-50 border border-green-200 text-green-800 rounded-xl p-4 text-sm text-center">
                ✅ Pesan berhasil terkirim! Kami akan membalas dalam 1×24 jam. Jazakumullahu khairan.
              </div>
            </form>
          </div>

          <!-- Google Maps — REAL EMBED -->
          <div class="rounded-2xl overflow-hidden shadow-card border border-parchment-300" role="region" aria-label="Peta lokasi PPTQ Nurul Iman">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3767.165357611131!2d106.74159357475415!3d-6.614038993380048!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e69c5419d4ebe49%3A0xa84ef3a9b64b6c75!2sPondok%20Pesantren%20Tahfidzil%20Qur&#39;an%20(%20PPTQ%20)%20Nurul%20Iman!5e1!3m2!1sid!2sid!4v1773634378172!5m2!1sid!2sid"
              width="100%"
              height="300"
              style="border:0; display:block;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Peta lokasi PPTQ Nurul Iman — Kp. Cipayung, Ciomas, Bogor"
            ></iframe>
            <div class="bg-white px-5 py-3.5 flex items-center justify-between gap-3 border-t border-parchment-200">
              <div>
                <p class="text-xs font-bold text-forest-800">PPTQ Nurul Iman</p>
                <p class="text-2xs text-ink-800/50">Kp. Cipayung, Desa Sukaharja, Kec. Ciomas, Kab. Bogor 16610</p>
              </div>
              <a href="https://maps.app.goo.gl/os3twwASvpf2DxaZ6" target="_blank" rel="noopener noreferrer"
                class="flex-shrink-0 px-4 py-2 bg-forest-900 hover:bg-forest-700 text-white text-xs font-bold rounded-full transition-colors shadow-sm">
                Buka Maps →
              </a>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  var form = document.getElementById('contact-form');
  var btn  = document.getElementById('submit-btn');
  var msg  = document.getElementById('success-msg');
  if (form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      btn.textContent = 'Mengirim…';
      btn.disabled = true;
      setTimeout(function() {
        msg.classList.remove('hidden');
        btn.textContent = 'Terkirim ✓';
        btn.classList.replace('bg-forest-900', 'bg-green-600');
        form.reset();
        msg.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }, 900);
    });
  }
</script>
