---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import ProgramCard from '../components/ProgramCard.astro';
import CTASection from '../components/CTASection.astro';

const base = '/pesantren-website';

const programs = [
  {
    icon: '📖',
    title: 'Tahfidz Al-Qur\'an',
    description: 'Program unggulan menghafal Al-Qur\'an 30 juz dengan metode Yanbu\'a yang telah teruji. Santri dibimbing oleh hafidz/hafidzah berpengalaman dengan evaluasi berkala dan sanad yang jelas.',
    features: ['Target 30 Juz dalam 3-4 tahun', 'Metode Yanbu\'a & Qira\'ati', 'Evaluasi hafalan harian', 'Sanad Al-Qur\'an yang bersambung', 'Sertifikat hafidz resmi'],
    accent: 'primary',
  },
  {
    icon: '📚',
    title: 'Kajian Kitab Kuning',
    description: 'Mempelajari ilmu agama Islam dari sumber aslinya — kitab-kitab klasik para ulama salaf. Program ini mencakup berbagai disiplin ilmu Islam yang komprehensif.',
    features: ['Fiqih (Safinah, Fathul Qarib)', 'Hadits (Bulughul Maram)', 'Tafsir (Tafsir Jalalain)', 'Nahwu-Sharaf (Jurumiyah)', 'Akidah (Aqidatul Awam)'],
    accent: 'emerald',
  },
  {
    icon: '🎓',
    title: 'Madrasah Diniyah',
    description: 'Pendidikan agama Islam yang terstruktur dan berjenjang untuk santriwati, mencakup semua aspek ilmu agama yang komprehensif.',,
    features: ['Jenjang Ula, Wustha, Ulya', 'Fiqih ibadah & muamalah', 'Sejarah Islam & peradaban', 'Bahasa Arab aktif', 'Akhlak & adab Islami'],
    accent: 'teal',
  },
  {
    icon: '🌐',
    title: 'Bahasa Arab & Inggris',
    description: 'Program bahasa intensif untuk membekali santriwati kemampuan komunikasi internasional. Lingkungan berbahasa Arab diciptakan dalam keseharian santriwati.',
    features: ['Muhādatsah harian', 'Grammar & Kosakata', 'Conversation English', 'Debat & pidato', 'Kelas bahasa ekstra'],
    accent: 'gold',
  },
  {
    icon: '💻',
    title: 'Teknologi & Keterampilan',
    description: 'Mempersiapkan santriwati menghadapi era digital dengan pembekalan teknologi informasi dan berbagai keterampilan praktis yang relevan.',
    features: ['Literasi digital & komputer', 'Desain grafis Islam', 'Wirausaha & ekonomi Islam', 'Pertanian & kemandirian', 'Jurnalistik & media'],
    accent: 'primary',
  },
  {
    icon: '🌙',
    title: 'Pesantren Kilat Ramadhan',
    description: 'Program intensif selama bulan Ramadhan yang terbuka untuk umum. Dirancang untuk pelajar SMP-SMA yang ingin merasakan nuansa pesantren.',
    features: ['Terbuka untuk umum', 'Tahsin & tilawah Al-Qur\'an', 'Kajian Ramadhan', 'I\'tikaf 10 malam terakhir', 'Sertifikat keikutsertaan'],
    accent: 'gold',
  },
];

const jadwal = [
  { waktu: '03.30 – 04.30', kegiatan: 'Tahajud & Persiapan Subuh' },
  { waktu: '04.30 – 06.00', kegiatan: 'Shalat Subuh berjamaah & Setoran Hafalan' },
  { waktu: '06.00 – 07.00', kegiatan: 'Sarapan & Persiapan Belajar' },
  { waktu: '07.00 – 09.00', kegiatan: 'Kegiatan Tahfidz Pagi' },
  { waktu: '09.00 – 12.00', kegiatan: 'Madrasah Diniyah / Kajian Kitab' },
  { waktu: '12.00 – 13.00', kegiatan: 'Shalat Dzuhur berjamaah & Istirahat' },
  { waktu: '13.00 – 15.00', kegiatan: 'Kegiatan Tahfidz Siang / Murojaa\'ah' },
  { waktu: '15.00 – 16.30', kegiatan: 'Shalat Ashar & Kegiatan Ekstrakurikuler' },
  { waktu: '17.30 – 19.30', kegiatan: 'Shalat Maghrib & Tilawah Al-Qur\'an' },
  { waktu: '19.30 – 20.30', kegiatan: 'Shalat Isya berjamaah' },
  { waktu: '20.30 – 22.00', kegiatan: 'Belajar Malam / Kajian Kitab' },
  { waktu: '22.00',         kegiatan: 'Istirahat' },
];
---

<BaseLayout title="Program Pendidikan" description="Program pendidikan unggulan PPTQ Nurul Iman: Tahfidz Al-Qur'an, Kitab Kuning, Madrasah Diniyah, dan pengembangan keterampilan santriwati.">
  <HeroSection
    variant="page"
    title="Program Pendidikan"
    subtitle="Kurikulum terintegrasi yang memadukan tahfidz Al-Qur'an, ilmu agama mendalam, dan keterampilan modern untuk membentuk santriwati yang komprehensif."
    bgImage={`${base}/images/students-activities/pesantren-kegiatan-santri-03.jpeg`}
    minHeight="min-h-[60vh]"
  />

  <!-- Programs grid -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14 reveal">
        <span class="inline-block px-4 py-1 text-xs font-bold uppercase tracking-widest text-forest-700 bg-forest-50 rounded-full border border-forest-100 mb-5">
          Program Kami
        </span>
        <h2 class="font-display font-bold text-4xl text-ink-900 mb-4">Enam Program Unggulan</h2>
        <p class="text-ink-800/55 max-w-xl mx-auto">
          Setiap program dirancang untuk memenuhi kebutuhan santriwati secara menyeluruh — ruhani, intelektual, dan sosial.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {programs.map((p, i) => (
          <div class="reveal" style={`animation-delay: ${i * 0.08}s`}>
            <ProgramCard {...p} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Jadwal Harian -->
  <section class="py-24 bg-parchment-100">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <span class="inline-block px-4 py-1 text-xs font-bold uppercase tracking-widest text-forest-700 bg-forest-50 rounded-full border border-forest-100 mb-4">
          Jadwal Keseharian
        </span>
        <h2 class="font-display font-bold text-3xl text-ink-900">Jadwal Kegiatan Harian Santri</h2>
        <p class="text-ink-800/55 mt-3">Setiap momen di pesantren adalah kesempatan belajar dan beribadah</p>
      </div>
      <div class="bg-white rounded-2xl shadow-lg overflow-hidden reveal">
        {jadwal.map((item, i) => (
          <div class={`flex items-center gap-6 px-6 py-4 ${i % 2 === 0 ? 'bg-white' : 'bg-forest-50/40'} border-b border-gray-100 last:border-0`}>
            <span class="font-mono text-sm font-bold text-forest-700 whitespace-nowrap w-36 flex-shrink-0">{item.waktu}</span>
            <span class="text-gray-700 text-sm">{item.kegiatan}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Metode -->
  <section class="py-24 bg-forest-900 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14 reveal">
        <span class="inline-block px-4 py-1 text-xs font-bold uppercase tracking-widest text-amber-400 bg-amber-500/10 rounded-full border border-amber-500/20 mb-5">
          Metode Pembelajaran
        </span>
        <h2 class="font-display font-bold text-4xl text-white">Pendekatan Pembelajaran PPTQ</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { icon: '🎯', title: 'Individual', desc: 'Setiap santriwati mendapat perhatian personal dari ustadzah pembimbing.' },
          { icon: '🔄', title: 'Repetisi', desc: 'Pengulangan hafalan secara konsisten melalui sistem setoran dan muroja\'ah.' },
          { icon: '👥', title: 'Halaqah', desc: 'Belajar dalam kelompok kecil (halaqah) untuk interaksi yang lebih intensif.' },
          { icon: '📊', title: 'Evaluasi', desc: 'Ujian berkala dan laporan perkembangan yang disampaikan kepada orang tua.' },
        ].map((m, i) => (
          <div class="text-center p-6 bg-forest-800/50 rounded-2xl border border-forest-700 reveal" style={`animation-delay: ${i * 0.1}s`}>
            <span class="text-4xl block mb-4">{m.icon}</span>
            <h4 class="font-display font-bold text-amber-400 text-lg mb-2">{m.title}</h4>
            <p class="text-sm text-forest-300 leading-relaxed">{m.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    title="Daftarkan Putri Anda"
    subtitle="Pilihkan pendidikan terbaik untuk generasi penerus Anda. Bergabunglah bersama keluarga besar PPTQ."
    ctaLabel="Daftar Sekarang"
    ctaHref={`${base}/pendaftaran`}
    secondLabel="Tanya via WhatsApp"
    secondHref="https://wa.me/6285887516141"
  />
</BaseLayout>
