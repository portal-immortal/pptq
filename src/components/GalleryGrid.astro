---
interface GalleryImage {
  src: string;
  alt: string;
}

interface Props {
  images:   GalleryImage[];
  columns?: 2 | 3 | 4;
  id?:      string;
}

const { images, columns = 3, id = 'gallery' } = Astro.props;

const gridCols: Record<number, string> = {
  2: 'grid-cols-2',
  3: 'grid-cols-2 sm:grid-cols-3',
  4: 'grid-cols-2 sm:grid-cols-3 lg:grid-cols-4',
};
---

<!-- Gallery grid -->
<div class={`grid ${gridCols[columns]} gap-3 sm:gap-4`} role="list" aria-label="Galeri foto">
  {images.map((img, i) => (
    <div
      role="listitem"
      class="reveal"
      style={`transition-delay: ${Math.min(i * 0.05, 0.5)}s`}
    >
      <button
        class="gallery-item img-zoom w-full aspect-square rounded-xl overflow-hidden cursor-zoom-in relative group focus-visible:ring-2 focus-visible:ring-forest-500 focus-visible:ring-offset-2"
        data-index={i}
        data-gallery={id}
        aria-label={`Lihat foto: ${img.alt}`}
        type="button"
      >
        <img
          src={img.src}
          alt={img.alt}
          class="w-full h-full object-cover"
          loading="lazy"
          decoding="async"
          onerror="this.src='https://placehold.co/400x400/15803d/ffffff?text=PPTQ'"
        />
        <!-- Hover overlay -->
        <div class="absolute inset-0 bg-forest-900/0 group-hover:bg-forest-900/40 transition-all duration-300 flex items-center justify-center" aria-hidden="true">
          <div class="w-10 h-10 rounded-full bg-white/90 flex items-center justify-center opacity-0 group-hover:opacity-100 scale-75 group-hover:scale-100 transition-all duration-300 shadow-lg">
            <svg class="w-5 h-5 text-forest-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"/>
            </svg>
          </div>
        </div>
      </button>
    </div>
  ))}
</div>

<!-- Lightbox modal -->
<div
  id={`lightbox-${id}`}
  role="dialog"
  aria-modal="true"
  aria-label="Tampilan foto penuh"
  class="fixed inset-0 z-[200] hidden bg-black/95 backdrop-blur-sm"
>
  <!-- Close button -->
  <button
    id={`lb-close-${id}`}
    aria-label="Tutup galeri"
    type="button"
    class="absolute top-4 right-4 z-10 w-11 h-11 rounded-full bg-white/10 hover:bg-white/20 text-white flex items-center justify-center transition-all"
  >
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
    </svg>
  </button>

  <!-- Counter -->
  <div id={`lb-counter-${id}`} class="absolute top-4 left-1/2 -translate-x-1/2 text-white/60 text-sm font-mono" aria-live="polite"></div>

  <!-- Main image area -->
  <div class="flex items-center justify-center w-full h-full px-16">
    <img
      id={`lb-img-${id}`}
      src=""
      alt=""
      class="max-w-full max-h-[85vh] object-contain rounded-lg shadow-2xl select-none"
    />
  </div>

  <!-- Prev button -->
  <button
    id={`lb-prev-${id}`}
    aria-label="Foto sebelumnya"
    type="button"
    class="absolute left-2 sm:left-4 top-1/2 -translate-y-1/2 w-11 h-11 rounded-full bg-white/10 hover:bg-white/25 text-white flex items-center justify-center transition-all hover:scale-110"
  >
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
  </button>

  <!-- Next button -->
  <button
    id={`lb-next-${id}`}
    aria-label="Foto berikutnya"
    type="button"
    class="absolute right-2 sm:right-4 top-1/2 -translate-y-1/2 w-11 h-11 rounded-full bg-white/10 hover:bg-white/25 text-white flex items-center justify-center transition-all hover:scale-110"
  >
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
  </button>

  <!-- Caption -->
  <div id={`lb-caption-${id}`} class="absolute bottom-6 left-1/2 -translate-x-1/2 text-white/70 text-sm text-center max-w-sm px-4" aria-live="polite"></div>
</div>

<script define:vars={{ id, images }}>
  (function () {
    const galleryId   = id;
    const imgs        = images;
    let currentIndex  = 0;
    let isOpen        = false;

    const lightbox    = document.getElementById(`lightbox-${galleryId}`);
    const lbImg       = document.getElementById(`lb-img-${galleryId}`);
    const lbCounter   = document.getElementById(`lb-counter-${galleryId}`);
    const lbCaption   = document.getElementById(`lb-caption-${galleryId}`);
    const btnClose    = document.getElementById(`lb-close-${galleryId}`);
    const btnPrev     = document.getElementById(`lb-prev-${galleryId}`);
    const btnNext     = document.getElementById(`lb-next-${galleryId}`);

    if (!lightbox || !lbImg) return;

    function showImage(index) {
      currentIndex = (index + imgs.length) % imgs.length;
      const img = imgs[currentIndex];
      lbImg.src = img.src;
      lbImg.alt = img.alt;
      if (lbCounter) lbCounter.textContent = `${currentIndex + 1} / ${imgs.length}`;
      if (lbCaption) lbCaption.textContent = img.alt;
    }

    function openLightbox(index) {
      isOpen = true;
      lightbox.classList.remove('hidden');
      lightbox.classList.add('flex');
      document.body.style.overflow = 'hidden';
      showImage(index);
      btnClose?.focus();
    }

    function closeLightbox() {
      isOpen = false;
      lightbox.classList.add('hidden');
      lightbox.classList.remove('flex');
      document.body.style.overflow = '';
    }

    // Attach click handlers to gallery items
    document.querySelectorAll(`.gallery-item[data-gallery="${galleryId}"]`).forEach(btn => {
      btn.addEventListener('click', () => {
        openLightbox(parseInt(btn.dataset.index || '0'));
      });
    });

    // Controls
    btnClose?.addEventListener('click', closeLightbox);
    btnPrev?.addEventListener('click', () => showImage(currentIndex - 1));
    btnNext?.addEventListener('click', () => showImage(currentIndex + 1));

    // Click outside image to close
    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox || e.target === lbImg.parentElement) closeLightbox();
    });

    // Keyboard navigation
    document.addEventListener('keydown', (e) => {
      if (!isOpen) return;
      if (e.key === 'Escape')       closeLightbox();
      if (e.key === 'ArrowLeft')    showImage(currentIndex - 1);
      if (e.key === 'ArrowRight')   showImage(currentIndex + 1);
    });

    // Touch/swipe support
    let touchStartX = 0;
    lightbox.addEventListener('touchstart', (e) => {
      touchStartX = e.changedTouches[0].clientX;
    }, { passive: true });
    lightbox.addEventListener('touchend', (e) => {
      const dx = e.changedTouches[0].clientX - touchStartX;
      if (Math.abs(dx) > 50) showImage(dx < 0 ? currentIndex + 1 : currentIndex - 1);
    }, { passive: true });
  })();
</script>
