---
const base = '/pptq';
const year = new Date().getFullYear();
---

<footer class="bg-forest-950 text-white border-ornament" role="contentinfo">
  <div class="h-px bg-gradient-to-r from-transparent via-amber-500/60 to-transparent"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 pb-12 border-b border-white/8">

      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href={`${base}/`} class="flex items-center gap-3 mb-5 group w-fit">
          <div class="w-14 h-14 rounded-full overflow-hidden ring-2 ring-white/10 group-hover:ring-amber-500/60 transition-all bg-forest-800 flex-shrink-0">
            <img src={`${base}/images/logo/logo pptq.png`} alt="Logo PPTQ Nurul Iman" width="56" height="56"
              class="w-full h-full object-cover" loading="lazy"
              onerror="this.parentElement.innerHTML='<div class=\'w-full h-full bg-forest-700 flex items-center justify-center font-bold text-white\'>NI</div>'" />
          </div>
          <div>
            <p class="font-display text-lg text-white">PPTQ Nurul Iman</p>
            <p class="text-xs text-white/40 leading-tight">Ciomas, Bogor</p>
          </div>
        </a>
        <p class="font-arabic text-xl text-amber-400 mb-3 leading-relaxed" lang="ar" aria-label="Bismillahirrahmanirrahim">
          بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيْمِ
        </p>
        <p class="text-sm text-white/50 leading-relaxed mb-6">
          Mencetak generasi penghafal Al-Qur'an yang berakhlak mulia dan bermanfaat bagi umat.
        </p>
        <!-- Socials -->
        <div class="flex gap-2.5" aria-label="Media sosial">
          {[
            { name: 'Instagram', href: 'https://instagram.com/pptqnuruliman_official',
              path: 'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z' },
            { name: 'YouTube', href: 'https://youtube.com',
              path: 'M23.495 6.205a3.007 3.007 0 0 0-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 0 0 .527 6.205a31.247 31.247 0 0 0-.522 5.805 31.247 31.247 0 0 0 .522 5.783 3.007 3.007 0 0 0 2.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 0 0 2.088-2.088 31.247 31.247 0 0 0 .5-5.783 31.247 31.247 0 0 0-.5-5.805zM9.609 15.601V8.408l6.264 3.602z' },
            { name: 'WhatsApp', href: 'https://wa.me/6285887516141',
              path: 'M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z' },
          ].map(s => (
            <a href={s.href} aria-label={s.name} target="_blank" rel="noopener noreferrer"
              class="w-9 h-9 rounded-full bg-white/8 hover:bg-amber-500/90 flex items-center justify-center transition-all duration-200 hover:scale-110">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d={s.path}/></svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="text-xs font-bold uppercase tracking-widest text-white/40 mb-5">Navigasi</h3>
        <ul class="space-y-2.5" role="list">
          {[
            ['Beranda',             `${base}/`],
            ['Profil Pesantren',    `${base}/profil`],
            ['Sejarah',             `${base}/sejarah`],
            ['Program Pendidikan',  `${base}/program-pendidikan`],
            ['Kegiatan Santri',     `${base}/kegiatan-santri`],
            ['Galeri',              `${base}/galeri`],
            ['Berita & Info',       `${base}/berita`],
            ['Pendaftaran',         `${base}/pendaftaran`],
          ].map(([label, href]) => (
            <li>
              <a href={href} class="text-sm text-white/55 hover:text-amber-300 transition-colors flex items-center gap-2 group">
                <span class="w-1 h-1 rounded-full bg-white/20 group-hover:bg-amber-400 transition-colors flex-shrink-0" aria-hidden="true"></span>
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Programs -->
      <div>
        <h3 class="text-xs font-bold uppercase tracking-widest text-white/40 mb-5">Program Unggulan</h3>
        <ul class="space-y-2.5" role="list">
          {["Tahfidz Al-Qur'an 30 Juz","Kajian Kitab Kuning","Madrasah Diniyah","Tahsin & Tilawah","Bahasa Arab & Inggris","Pesantren Kilat Ramadhan"].map(p => (
            <li class="flex items-start gap-2 text-sm text-white/55">
              <span class="w-1 h-1 rounded-full bg-amber-500/60 flex-shrink-0 mt-2" aria-hidden="true"></span>
              {p}
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-xs font-bold uppercase tracking-widest text-white/40 mb-5">Hubungi Kami</h3>
        <address class="not-italic space-y-4">
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-lg bg-white/8 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <p class="text-sm text-white/55 leading-relaxed">Kp. Cipayung No.1, Desa Sukaharja, Kec. Ciomas, Kab. Bogor, Jawa Barat 16610</p>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg bg-white/8 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            </div>
            <div>
              <a href="https://wa.me/6281317030272" class="text-sm text-white/70 hover:text-amber-300 transition-colors block">0813-1703-0272 (KH Ubaidilah)</a>
              <a href="https://wa.me/6285887516141" class="text-sm text-white/70 hover:text-amber-300 transition-colors block">0858-8751-6141 (Umi Hj. Eli HS, SQ)</a>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg bg-white/8 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <a href="mailto:pptqnurulimancipayung@gmail.com" class="text-xs text-white/70 hover:text-amber-300 transition-colors whitespace-nowrap">pptqnurulimancipayung@gmail.com</a>
          </div>
        </address>
      </div>
    </div>

    <!-- Bottom -->
    <div class="pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-white/30">&copy; {year} PPTQ Nurul Iman. Semua hak dilindungi.</p>
      <p class="font-arabic text-base text-amber-500/60" aria-label="Ya Allah jadikanlah kami termasuk Ahlul Quran">اللّٰهُمَّ اجْعَلْنَا مِنْ أَهْلِ الْقُرْآنِ</p>
    </div>
  </div>
</footer>
