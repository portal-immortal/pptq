---
interface Props {
  title:        string;
  subtitle?:    string;
  ctaLabel:     string;
  ctaHref:      string;
  secondLabel?: string;
  secondHref?:  string;
}
const { title, subtitle, ctaLabel, ctaHref, secondLabel, secondHref } = Astro.props;
---

<section class="relative overflow-hidden bg-forest-900" aria-label="Call to action">
  <!-- Background pattern -->
  <div class="absolute inset-0 bg-pattern-star opacity-60 pointer-events-none"></div>
  <!-- Photo strip on right side -->
  <div class="absolute top-0 right-0 w-1/3 h-full opacity-20 hidden lg:block"
    style="background: url('/images/students-activities/pesantren-kegiatan-santri-08.jpeg') center/cover no-repeat;">
    <div class="absolute inset-0 bg-gradient-to-r from-forest-900 to-transparent"></div>
  </div>
  <!-- Gold top/bottom borders -->
  <div class="h-px bg-gradient-to-r from-transparent via-amber-500/50 to-transparent"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="lg:max-w-[60%] reveal">
      <!-- Arabic quote -->
      <p class="font-arabic text-2xl text-amber-400/80 mb-6 leading-relaxed" lang="ar">
        إِنَّ اللَّهَ وَمَلَائِكَتَهُ يُصَلُّونَ عَلَى النَّبِيِّ
      </p>

      <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl text-white leading-tight mb-5">{title}</h2>

      {subtitle && (
        <p class="text-forest-200/70 text-lg leading-relaxed mb-10 max-w-xl">{subtitle}</p>
      )}

      <div class="flex flex-col sm:flex-row gap-4">
        <a href={ctaHref}
          class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-amber-500 hover:bg-amber-400 text-white font-bold rounded-full shadow-gold transition-all hover:scale-105 text-sm">
          {ctaLabel}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
        {secondLabel && secondHref && (
          <a href={secondHref}
            class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-white/10 hover:bg-white/15 text-white font-medium rounded-full border border-white/20 transition-all text-sm">
            {secondLabel}
          </a>
        )}
      </div>
    </div>
  </div>

  <div class="h-px bg-gradient-to-r from-transparent via-amber-500/50 to-transparent"></div>
</section>
