---
const base = '/pptq';
const navLinks = [
  { href: `${base}/`,                    label: 'Beranda' },
  { href: `${base}/profil`,             label: 'Profil' },
  { href: `${base}/sejarah`,            label: 'Sejarah' },
  { href: `${base}/program-pendidikan`, label: 'Program' },
  { href: `${base}/kegiatan-santri`,    label: 'Kegiatan' },
  { href: `${base}/galeri`,             label: 'Galeri' },
  { href: `${base}/berita`,             label: 'Berita' },
  { href: `${base}/kontak`,             label: 'Kontak' },
];
---

<!-- ── Announcement topbar ── -->
<div id="topbar" class="bg-forest-900 text-white text-xs py-2 px-4 text-center transition-all duration-300 overflow-hidden" style="max-height:40px">
  <div class="max-w-7xl mx-auto flex items-center justify-center gap-6">
    <span class="hidden sm:flex items-center gap-1.5">
      <svg class="w-3.5 h-3.5 text-amber-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
      <span class="text-white/70">Kp. Cipayung, Ciomas, Bogor</span>
    </span>
    <span class="w-px h-3 bg-white/20 hidden sm:block"></span>
    <a href="https://wa.me/6281317030272" class="flex items-center gap-1.5 text-amber-300 hover:text-amber-200 transition-colors font-medium">
      <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      0813-1703-0272
    </a>
    <span class="w-px h-3 bg-white/20"></span>
    <a href={`mailto:pptqnurulimancipayung@gmail.com`} class="text-white/60 hover:text-white/90 transition-colors hidden md:block">
      pptqnurulimancipayung@gmail.com
    </a>
    <span class="w-px h-3 bg-white/20 hidden md:block"></span>
    <a href="https://instagram.com/pptqnuruliman_official" target="_blank" rel="noopener noreferrer" class="text-white/60 hover:text-amber-300 transition-colors hidden md:block">
      @pptqnuruliman_official
    </a>
  </div>
</div>

<!-- ── Main navbar ── -->
<header id="navbar" class="sticky top-0 z-50 transition-all duration-300 bg-white/95 backdrop-blur-md border-b border-forest-100/60 shadow-sm" role="banner">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <nav class="flex items-center justify-between h-18" aria-label="Navigasi utama">

      <!-- Logo -->
      <a href={`${base}/`} class="flex items-center gap-3 group" aria-label="PPTQ Nurul Iman — Beranda">
        <div class="w-12 h-12 rounded-full overflow-hidden ring-2 ring-forest-100 group-hover:ring-amber-400 transition-all duration-300 shadow-sm bg-forest-50 flex-shrink-0">
          <img
            src={`${base}/images/logo/logo pptq.png`}
            alt="Logo PPTQ Nurul Iman"
            width="48" height="48"
            class="w-full h-full object-cover"
            onerror="this.parentElement.innerHTML='<div class=\'w-full h-full bg-forest-900 flex items-center justify-center font-bold text-white text-sm\'>NI</div>'"
          />
        </div>
        <div class="leading-tight">
          <p class="font-display text-forest-900 font-normal text-base leading-tight">PPTQ Nurul Iman</p>
          <p class="text-2xs text-forest-600 font-medium tracking-wide uppercase leading-tight hidden sm:block">Ciomas, Bogor</p>
        </div>
      </a>

      <!-- Desktop links -->
      <ul class="hidden lg:flex items-center gap-1" role="list">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class="nav-link relative px-3.5 py-2 text-sm font-medium text-forest-800 hover:text-forest-900 rounded-lg transition-all duration-200 hover:bg-forest-50"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- CTA + mobile toggle -->
      <div class="flex items-center gap-3">
        <a
          href={`${base}/pendaftaran`}
          class="hidden sm:inline-flex items-center gap-2 px-5 py-2.5 bg-forest-900 hover:bg-forest-700 text-white text-sm font-semibold rounded-full shadow-md transition-all duration-200 hover:scale-105 hover:shadow-lg"
        >
          Daftar Santri
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>

        <button
          id="hamburger"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Buka menu"
          class="lg:hidden w-10 h-10 rounded-xl flex flex-col items-center justify-center gap-1.5 text-forest-900 hover:bg-forest-50 transition-colors"
        >
          <span id="hb1" class="w-5 h-0.5 bg-current rounded-full transition-all duration-300 origin-center"></span>
          <span id="hb2" class="w-5 h-0.5 bg-current rounded-full transition-all duration-300"></span>
          <span id="hb3" class="w-5 h-0.5 bg-current rounded-full transition-all duration-300 origin-center"></span>
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile drawer -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-forest-100 bg-white" role="navigation" aria-label="Menu mobile">
    <div class="max-w-7xl mx-auto px-4 py-4 space-y-1">
      {navLinks.map(link => (
        <a href={link.href} class="mobile-nav-link flex items-center px-4 py-3 text-sm font-medium text-forest-800 hover:text-forest-900 hover:bg-forest-50 rounded-xl transition-all">
          {link.label}
        </a>
      ))}
      <div class="pt-2 grid grid-cols-2 gap-2">
        <a href={`${base}/pendaftaran`} class="flex items-center justify-center py-3 bg-forest-900 text-white text-sm font-semibold rounded-xl">Daftar Santri</a>
        <a href="https://wa.me/6285887516141" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center py-3 bg-green-500 text-white text-sm font-semibold rounded-xl">WhatsApp</a>
      </div>
    </div>
  </div>
</header>

<script>
  const hamburger  = document.getElementById('hamburger')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const hb1 = document.getElementById('hb1')!;
  const hb2 = document.getElementById('hb2')!;
  const hb3 = document.getElementById('hb3')!;
  let open = false;

  hamburger.addEventListener('click', () => {
    open = !open;
    hamburger.setAttribute('aria-expanded', String(open));
    mobileMenu.classList.toggle('hidden', !open);
    hb1.style.transform = open ? 'translateY(7px) rotate(45deg)' : '';
    hb2.style.opacity   = open ? '0' : '';
    hb3.style.transform = open ? 'translateY(-7px) rotate(-45deg)' : '';
  });

  document.querySelectorAll('.mobile-nav-link').forEach(l => l.addEventListener('click', () => {
    open = false; mobileMenu.classList.add('hidden');
    hamburger.setAttribute('aria-expanded', 'false');
    hb1.style.transform = hb3.style.transform = ''; hb2.style.opacity = '';
  }));
  document.addEventListener('keydown', e => { if (e.key === 'Escape' && open) hamburger.click(); });

  // Active page highlight with pill style
  const path = window.location.pathname.replace(/\/$/, '');
  document.querySelectorAll('.nav-link').forEach(link => {
    const href = ((link as HTMLAnchorElement).getAttribute('href') || '').replace(/\/$/, '');
    const isHome   = href === '';
    const isActive = isHome
      ? (path === '' || path === '')
      : href !== '' && path.startsWith(href);
    if (isActive) {
      link.classList.add('bg-forest-900', 'text-white', '!text-white');
      link.classList.remove('text-forest-800', 'hover:bg-forest-50');
      link.setAttribute('aria-current', 'page');
    }
  });

  // Hide topbar on scroll (after 80px)
  const topbar = document.getElementById('topbar')!;
  window.addEventListener('scroll', () => {
    if (window.scrollY > 80) {
      topbar.style.maxHeight = '0';
      topbar.style.paddingTop = '0';
      topbar.style.paddingBottom = '0';
    } else {
      topbar.style.maxHeight = '40px';
      topbar.style.paddingTop = '';
      topbar.style.paddingBottom = '';
    }
  }, { passive: true });
</script>
