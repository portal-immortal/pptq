---
interface Props {
  icon:        string;
  title:       string;
  description: string;
  features?:   string[];
  href?:       string;
  accent?:     'forest' | 'amber' | 'teal' | 'slate';
}
const { icon, title, description, features = [], href = '#', accent = 'forest' } = Astro.props;

const accentMap: Record<string, { bg: string; text: string; border: string; dot: string }> = {
  forest: { bg: 'bg-forest-900', text: 'text-white',      border: 'border-forest-800', dot: 'bg-amber-400' },
  amber:  { bg: 'bg-amber-500',  text: 'text-white',      border: 'border-amber-400',  dot: 'bg-white' },
  teal:   { bg: 'bg-teal-700',   text: 'text-white',      border: 'border-teal-600',   dot: 'bg-teal-200' },
  slate:  { bg: 'bg-slate-800',  text: 'text-white',      border: 'border-slate-700',  dot: 'bg-amber-400' },
};
const a = accentMap[accent] ?? accentMap.forest;
---

<article class="group bg-white rounded-2xl overflow-hidden shadow-card hover:shadow-card-hover card-lift border border-parchment-300 flex flex-col h-full">
  <!-- Coloured top band -->
  <div class={`${a.bg} px-6 pt-7 pb-5`}>
    <span class="text-3xl block mb-3" aria-hidden="true">{icon}</span>
    <h3 class={`font-display text-xl ${a.text} leading-tight`}>{title}</h3>
  </div>

  <!-- Body -->
  <div class="px-6 pt-5 pb-6 flex flex-col flex-1">
    <p class="text-sm text-ink-800/70 leading-relaxed mb-4">{description}</p>

    {features.length > 0 && (
      <ul class="space-y-2 mb-5 flex-1" role="list">
        {features.map(f => (
          <li class="flex items-start gap-2.5 text-sm text-ink-800/80">
            <span class={`w-1.5 h-1.5 rounded-full ${a.bg === 'bg-forest-900' ? 'bg-forest-600' : a.bg === 'bg-amber-500' ? 'bg-amber-500' : 'bg-teal-600'} flex-shrink-0 mt-1.5`} aria-hidden="true"></span>
            {f}
          </li>
        ))}
      </ul>
    )}

    <a href={href} class="mt-auto inline-flex items-center gap-1.5 text-xs font-bold uppercase tracking-wide text-forest-700 hover:text-forest-900 transition-colors group/link">
      Pelajari lebih lanjut
      <svg class="w-3.5 h-3.5 transition-transform group-hover/link:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
    </a>
  </div>
</article>
